# This server can target two environments. Which file is loaded is selected by
# the MOONROLL_ENV variable (set per registration in the root .mcp.json):
#   MOONROLL_ENV unset / "prod"  -> loads .env       (registers as "moonroll-debug")
#   MOONROLL_ENV=dev             -> loads .env.dev    (registers as "moonroll-debug-dev")
#
# Copy this file to .env (prod) and .env.dev (dev) and fill in each environment's
# values. Both files are gitignored.

MONGODB_URL=mongodb://localhost:27017/moonroll
AWS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDWATCH_LOG_GROUP=api-prod
MCP_PORT=3456
# HTTP mode only. Defaults to 127.0.0.1; set 0.0.0.0 to expose beyond localhost —
# in that case MCP_AUTH_TOKEN is strongly recommended (clients must then send
# an "Authorization: Bearer <token>" header).
MCP_HOST=127.0.0.1
MCP_AUTH_TOKEN=
